# ==============================================================================
#  Trading Signals Project .gitignore
# ==============================================================================

# --- OS / System Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- IDEs and Text Editors ---
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.lock-wscript

# --- Node.js (Vue Frontend) ---
node_modules/
dist/
/dist
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
.cache/

# --- Go Backend ---
/trading_api/trading_api*
/trading_api/vendor/
/trading_api/*.exe

# --- Python (Scripts) ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ipynb_checkpoints/
*.egg-info/
.venv/
env/
venv/
ENV/

# --- Temporary generated charts & log data ---
*rrgchart.png
scripts/*rrgchart.png
temp/
*.log

# --- Environment Credentials (CRITICAL for security) ---
.env
.env.local
.env.*.local
*/.env
scripts/.env
trading_api/.env

# --- Project specific legacy server files ---
packages/server-renderer/basic.js
packages/server-renderer/build.dev.js
packages/server-renderer/build.prod.js
packages/server-renderer/server-plugin.js
packages/server-renderer/client-plugin.js
packages/template-compiler/build.js
packages/template-compiler/browser.js
explorations
